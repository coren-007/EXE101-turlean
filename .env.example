# ============================================
# .env.example — GiaSuConnect (Turlean)
# Copy file này thành .env và điền giá trị
# ============================================

# --- Database ---
# Supabase PostgreSQL (Production / default):
# 1. Tạo account tại https://supabase.com
# 2. Tạo project mới
# 3. Copy connection string từ Settings > Database
#    - Pooling (transaction mode, port 6543): dùng cho DATABASE_URL
#    - Direct (session mode, port 5432): dùng cho DIRECT_URL
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# --- Cron Job Secret (tùy chọn) ---
# Tạo random string: openssl rand -hex 32
# CRON_SECRET=your-random-secret-here

# --- Payment (tương lai - Phase 2) ---
# VNPay Sandbox (miễn phí test):
# VNPAY_TMN_CODE=your-merchant-code
# VNPAY_HASH_SECRET=your-hash-secret
# VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# VNPAY_RETURN_URL=http://localhost:3000/api/payments/callback

# --- Email (tương lai - Phase 2) ---
# Resend (FREE 3,000 emails/tháng):
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=GiaSuConnect <noreply@giasuconnect.vn>

# --- File Upload (tương lai - Phase 2) ---
# Cloudinary (FREE 25GB storage):
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# --- Error Monitoring (tương lai) ---
# Sentry (FREE 5,000 errors/tháng):
# SENTRY_DSN=https://xxxx@sentry.io/xxxx

# --- App Config ---
NEXT_PUBLIC_APP_NAME=GiaSuConnect
NEXT_PUBLIC_APP_URL=http://localhost:3000
